# API base URL. Used when you run or build the app.
# Local dev (default if unset): http://localhost:8080/api/v1
# On VPS (same server as frontend): use VPS IP or domain, NOT localhost,
# or the browser will get "Network Error" when searching:
#   REACT_APP_API_URL=http://YOUR_VPS_IP:8080/api/v1
REACT_APP_API_URL=http://localhost:8080/api/v1
